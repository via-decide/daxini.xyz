{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": null,
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/early-access",
      "destination": "/zayvora-login/index.html"
    },
    {
      "source": "/zayvora-login",
      "destination": "/zayvora-login/index.html"
    },
    {
      "source": "/zayvora-onboarding",
      "destination": "/zayvora-onboarding/index.html"
    },
    {
      "source": "/zayvora-chat",
      "destination": "/zayvora-chat/index.html"
    },
    {
      "source": "/zayvora",
      "destination": "/zayvora/index.html"
    },
    {
      "source": "/login",
      "destination": "/zayvora-login/index.html"
    },
    {
      "source": "/workspace",
      "destination": "/workspace/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
