{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": true,
  "redirects": [
    { "source": "/early-access", "destination": "/zayvora-onboarding/", "permanent": true }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/((?!api/|.*\\.).*)", "destination": "/index.html" }
  ]
}
